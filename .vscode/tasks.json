{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Pico: Compile",
            "type": "process",
            "isBuildCommand": true,
            "command": "${userHome}/.pico-sdk/ninja/v1.12.1/ninja",
            "args": ["-C", "${workspaceFolder}/pico/usbprinter/build"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Pico: Flash (debug probe)",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd",
            "args": [
                "-s", "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/rp2040.cfg",
                "-c", "adapter speed 5000; program \"${workspaceFolder}/pico/usbprinter/build/usbprinter.elf\" verify reset exit"
            ],
            "problemMatcher": []
        },
        {
            "label": "Pico: Run (picotool / BOOTSEL)",
            "type": "process",
            "command": "${userHome}/.pico-sdk/picotool/2.2.0-a4/picotool/picotool",
            "args": [
                "load",
                "${workspaceFolder}/pico/usbprinter/build/usbprinter.elf",
                "-fx"
            ],
            "problemMatcher": []
        },
        {
            "label": "Pico: Rescue Reset",
            "type": "process",
            "command": "${userHome}/.pico-sdk/openocd/0.12.0+dev/openocd",
            "args": [
                "-s", "${userHome}/.pico-sdk/openocd/0.12.0+dev/scripts",
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/rp2040-rescue.cfg",
                "-c", "adapter speed 5000; reset halt; exit"
            ],
            "problemMatcher": []
        }
    ]
}
